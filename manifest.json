{
  "manifest_version": 3,
  "name": "tabily",
  "version": "0.1.0.1",
  "description": "A modular new tab dashboard with draggable, resizable panes.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage", "unlimitedStorage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "{4b53e80a-c5f8-452a-a9c2-7e292e13020a}",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
